# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env files (secrets) — .env, .env.remote/.env.local/etc, and *.env (e.g. prod.env)
.env
.env.*
*.env

# Editor/IDE
.idea/
.vscode/

# Transient upstream spec cache (pulled by `just sync`; never committed)
specs/.cache/

# Generated release notes
RELEASE_NOTES.md

# Built docs site
site/

# Generated docs artifacts (produced by just docs-prepare; never committed)
docs/reference/unifi.md
docs/openapi/*.openapi.json

# Working planning docs (kept locally, excluded from the site and VCS)
docs/plans/

# Superpowers brainstorming specs and plans (working artifacts, never committed)
docs/superpowers/

# Compiled CLI binary (just build-cli)
/bin/

# Stray specgen binary from `go build ./tools/specgen`
/specgen

# Local assessment artifacts (working references / deployment-specific output, never committed)
skills/executed-commands.md
unifi-assessment-*.md
unifi-assessment-*.html
